# Gemini API key from https://aistudio.google.com/apikey
# scan + qa run on the free tier; generate needs the key's Cloud project to have billing enabled
GEMINI_API_KEY=""

# Cloudinary credentials. If omitted, the pipeline falls back to the values in backend/.env
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Root folder for uploaded catalog images (matches backend convention)
CLOUDINARY_FOLDER="sunfabb"
