# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Backend ─────────────────────────────────────────────────────────────────

# URL of the NestJS backend. Trailing slash optional.
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"

# ─── Feature flags ───────────────────────────────────────────────────────────

# Controls whether the /account/** e-commerce pages are open to users.
# Set to "true" in Vercel (or your hosting env) only when the feature is
# ready for real users. In prod this MUST stay "false" until checkout/payments
# are complete and tested. In local dev set to "true" to work on account pages.
ECOMMERCE_ENABLED="false"

# ─── SEO & Analytics ─────────────────────────────────────────────────────────

# Canonical origin used in sitemap.xml, robots.txt, and JSON-LD schemas.
# Must match the production domain exactly (no trailing slash).
NEXT_PUBLIC_SITE_URL="https://sunfabb.com"

# GA4 Measurement ID (G-XXXXXXXXXX). Leave blank to disable analytics.
# Owner action: create a GA4 property at analytics.google.com to get this.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
