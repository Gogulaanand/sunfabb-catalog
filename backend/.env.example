# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Required secrets must throw at boot if missing
# (CLAUDE.md rule 12 / D31) — there are no safe fallbacks for anything below
# marked "required". Optional vars list their default.

# ─── Core (Phases 0–5) ───────────────────────────────────────────────────────

# Neon pooled connection string — get this from your Neon project dashboard.
# Must include ?sslmode=require for Neon (D29 keys SSL off this flag).
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Admin JWT (single admin — D10). JWT_SECRET is required, no fallback (D31).
JWT_SECRET="<openssl rand -base64 48>"
JWT_EXPIRES_IN="24h"                 # optional, defaults to 24h

# Single admin login. Generate a strong password + bcrypt hash; set these as
# host env vars in prod (Render dashboard), never reuse the dev password.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="<bcrypt hash>"

# Cloudinary (image upload/delivery). Required for the admin image endpoints.
CLOUDINARY_CLOUD_NAME="<cloud name>"
CLOUDINARY_API_KEY="<api key>"
CLOUDINARY_API_SECRET="<api secret>"

# Storefront origin for CORS. Optional locally; set to the live origin in prod.
FRONTEND_URL="http://localhost:3000"

# ─── Phase 6 — e-commerce (add per milestone; see .omc/plans/2026-06-21-phase6-ecommerce.md §6) ───

# 6.1 Customer auth — SEPARATE secret from JWT_SECRET (D32). Required once 6.1 ships.
# CUSTOMER_JWT_SECRET="<openssl rand -base64 48>"
# CUSTOMER_JWT_EXPIRES_IN="7d"        # optional, defaults to 7d

# 6.4 Razorpay (test keys to build, live keys gated to 6.10). Required for payments.
# RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
# RAZORPAY_KEY_SECRET="<key secret>"
# RAZORPAY_WEBHOOK_SECRET="<webhook secret — separate from the API key>"

# 6.4 (C9) Abandoned-checkout expiry. Hours a PENDING_PAYMENT order may sit before
# the hourly cron (and POST /admin/expiry/orders) releases its reserved stock.
# Must be a positive integer; defaults to 24 if unset. See D41.
ORDER_EXPIRY_HOURS=24

# 6.5 GST / invoicing. Drives intra- vs inter-state tax split + invoice series.
# SELLER_GSTIN="<15-char GSTIN>"
# SELLER_STATE_CODE="<2-digit GST state code>"
# INVOICE_SERIES_PREFIX="SF"          # optional

# 6.6 Shiprocket (sandbox to build, live gated to 6.10).
# SHIPROCKET_EMAIL="<account email>"
# SHIPROCKET_PASSWORD="<account password>"
# SHIPROCKET_WEBHOOK_TOKEN="<token validating inbound tracking webhooks>"

# 6.7 Resend transactional email. EMAIL_FROM must be on a verified domain.
# RESEND_API_KEY="re_xxxxxxxx"
# EMAIL_FROM="orders@sunfabb.com"

# Used for email links, Razorpay callback, and webhook registration.
# APP_BASE_URL="https://sunfabb.com"
